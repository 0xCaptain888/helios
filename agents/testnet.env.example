# Copy to agents/testnet.env and fill in (testnet.env is gitignored).
# Supports Casper Wallet secp256k1 keys directly — no conversion needed.
#
# Role mapping:
#   FUND_AGENT_KEY  = Account 2 (deployer, ~4600 CSPR)
#   RISK_AGENT_KEY  = Account 2 (same key — single wallet demo)
#   ORACLE_*_KEY    = Accounts 3, 4, 5 (each needs ~100 CSPR)
#
# HASH fields are filled automatically by:
#   python3 scripts/casper_deploy.py deploy-all --key keys/account2_secret_key.pem

# ── Key paths ──────────────────────────────────────────────────────────────────
ORACLE_TBILL_KEY=keys/account3_secret_key.pem
ORACLE_GOLD_KEY=keys/account4_secret_key.pem
ORACLE_REINDEX_KEY=keys/account5_secret_key.pem
FUND_AGENT_KEY=keys/account2_secret_key.pem
RISK_AGENT_KEY=keys/account2_secret_key.pem

# ── Contract hashes (raw hex, no "hash-" prefix) ───────────────────────────────
REGISTRY_HASH=
MARKET_HASH=
VAULT_HASH=
GOV_HASH=

# ── Deployer (auto-filled by deploy-all) ───────────────────────────────────────
DEPLOYER_ACCOUNT=account-hash-133b4fd8051e6acbdef6c55206be976ac5c3736fa632972cb9e50b6d1c5bd822
