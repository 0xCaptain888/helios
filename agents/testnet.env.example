# Copy to agents/testnet.env and fill in (testnet.env is gitignored).
# Keys: paths to Casper testnet secret keys (ed25519 PEM), one per agent.
# Hashes: contract entity hashes recorded after deployment (docs/TESTNET.md step 2).
ORACLE_TBILL_KEY=keys/oracle_tbill/secret_key.pem
ORACLE_GOLD_KEY=keys/oracle_gold/secret_key.pem
ORACLE_REINDEX_KEY=keys/oracle_reindex/secret_key.pem
FUND_AGENT_KEY=keys/fund_agent/secret_key.pem
RISK_AGENT_KEY=keys/risk_agent/secret_key.pem
REGISTRY_HASH=entity-contract-...
MARKET_HASH=entity-contract-...
VAULT_HASH=entity-contract-...
GOV_HASH=entity-contract-...
